{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-sdk": "node -e \"const fs=require('fs');const p=require('path');const src=p.resolve(__dirname,'../../../SDK');const dst=p.resolve(__dirname,'node_modules/@geyed/sdk');fs.rmSync(dst,{recursive:true,force:true});fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(p.join(src,'dist')))fs.copyFileSync(p.join(src,'dist',f),p.join(dst,f));fs.copyFileSync(p.join(src,'package.json'),p.join(dst,'package.json'));console.log('SDK synced')\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@geyed/sdk": "file:../../../SDK/dist",
    "@tanstack/react-query": "^5.91.2",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.91.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
